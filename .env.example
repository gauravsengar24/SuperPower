# SuperTrading AI — Environment Variables
# Copy this to .env and fill in your keys
# https://github.com/gauravsengar24/SuperPower

# === LLM PROVIDERS (choose one) ===
# OpenAI (default)
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Google (Gemini)
GOOGLE_API_KEY=AIza...

# xAI (Grok)
XAI_API_KEY=...

# DeepSeek
DEEPSEEK_API_KEY=...

# Qwen (DashScope International)
DASHSCOPE_API_KEY=...
# Qwen (DashScope China)
DASHSCOPE_CN_API_KEY=...

# OpenRouter
OPENROUTER_API_KEY=...

# === TRADING CONFIG ===
TRADING_LLM_PROVIDER=openai
TRADING_DEEP_THINK_LLM=gpt-5.5
TRADING_QUICK_THINK_LLM=gpt-5.4-mini
TRADING_MAX_DEBATE_ROUNDS=1
TRADING_MAX_RISK_ROUNDS=1
TRADING_OUTPUT_LANGUAGE=English
TRADING_TEMPERATURE=0.7

# === DATA VENDORS ===
# Alpha Vantage (free tier: 5 calls/min)
ALPHA_VANTAGE_API_KEY=...

# FRED (macro data — free API key)
FRED_API_KEY=...

# === BROKER — Alpaca (free paper trading) ===
# No per-query charges
# Sign up at https://alpaca.markets
ALPACA_API_KEY=...
ALPACA_SECRET_KEY=...
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# === AEGIS RISK GATES ===
TRADING_MAX_POSITIONS=10
TRADING_MAX_POSITION_PCT=0.25
TRADING_MAX_DAILY_DRAWDOWN=0.05
TRADING_MAX_TRAILING_DRAWDOWN=0.15
TRADING_VOLATILITY_THRESHOLD=0.40
TRADING_DEFAULT_RISK_PER_TRADE=0.02

# === DASHBOARD ===
TRADING_DASHBOARD_PORT=8501
TRADING_DASHBOARD_HOST=0.0.0.0
